{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "meticulous",
  "scopeName": "source.meticulous",
  "patterns": [
    { "include": "#comment" },
    { "include": "#heading" },
    { "include": "#statement" },
    { "include": "#justification" },
    { "include": "#relation" },
    { "include": "#string" },
    { "include": "#term-subject" },
    { "include": "#term-predicate" },
    { "include": "#operator" },
    { "include": "#prose" },
    { "include": "#constant" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.meticulous"
    },
    "heading": {
      "match": "^\\s*(#{1,6})\\s+(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.heading.meticulous" },
        "2": { "name": "markup.heading.meticulous" }
      }
    },
    "statement": {
      "match": "^\\s*(prop|claim|table|check|argument|proof|venn|premise|conclude|analyze|map)\\b",
      "captures": {
        "1": { "name": "keyword.control.meticulous" }
      }
    },
    "justification": {
      "match": "\\b(by)\\s+([\\w-]+)(?:\\s+(from)\\b)?",
      "captures": {
        "1": { "name": "keyword.control.meticulous" },
        "2": { "name": "entity.name.function.meticulous" },
        "3": { "name": "keyword.control.meticulous" }
      }
    },
    "relation": {
      "match": "\\b(supports|contradicts|entails|presupposes|equivalent-to|equivalent)\\b",
      "name": "keyword.other.relation.meticulous"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.meticulous"
    },
    "operator": {
      "match": "->|<->|<>|→|↔|∧|∨|¬|⊕|□|◇|∀|∃|\\[\\]|&|\\||~|!|\\b(and|or|not|implies|iff|xor|necessarily|possibly|forall|exists)\\b",
      "name": "keyword.operator.logical.meticulous"
    },
    "prose": {
      "match": "\\b(If|if|then|Either|either|neither|nor|All|all|No|Some|some|Every|every|are|is|Therefore|therefore|Thus|thus|Hence|hence)\\b",
      "name": "keyword.other.prose.meticulous"
    },
    "term-subject": {
      "comment": "the class term after a quantifier — the 'x' in 'All x are ...'",
      "match": "\\b(?i:all|no|some|every)\\s+([A-Za-z][\\w-]*)",
      "captures": {
        "1": { "name": "variable.other.term.meticulous" }
      }
    },
    "term-predicate": {
      "comment": "the class term after a copula — the 'y' in '... are y' / '... is a y'",
      "match": "\\b(?i:are|is)\\s+(?i:not\\s+)?(?i:an?\\s+)?([A-Za-z][\\w-]*)",
      "captures": {
        "1": { "name": "variable.other.term.meticulous" }
      }
    },
    "constant": {
      "match": "\\b(true|false)\\b|⊤|⊥",
      "name": "constant.language.meticulous"
    }
  }
}
